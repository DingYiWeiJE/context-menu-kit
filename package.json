{
  "name": "context-menu-kit",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "A lightweight UI kit for customizable context menus.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev:react": "pnpm --filter react dev",
    "build": "pnpm -r --filter \"@context-menu-kit/*\" build",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepare": "husky"
  },
  "keywords": [
    "context-menu",
    "right-click-menu",
    "react",
    "vue",
    "monorepo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DingYiWeiJE/context-menu-kit.git"
  },
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.10.0",
  "bugs": {
    "url": "https://github.com/DingYiWeiJE/context-menu-kit/issues"
  },
  "homepage": "https://github.com/DingYiWeiJE/context-menu-kit#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint"
    ]
  }
}
